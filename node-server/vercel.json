{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/predict-batch", "dest": "/api/predict-batch.js" },
    { "src": "/api/predict-single", "dest": "/api/predict-single.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
